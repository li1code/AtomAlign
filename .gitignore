# ==============================================================================
#                      ATOMQUEST MONOREPO MASTER .GITIGNORE
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Dependency Directories (Node / Yarn / Pnpm / Bower)
# ------------------------------------------------------------------------------
node_modules/
**/node_modules/
bower_components/
jspm_packages/
web_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ------------------------------------------------------------------------------
# 2. SENSITIVE ENVIRONMENT VARIABLES & SECRETS (CRITICAL FOR SECURITY)
# ------------------------------------------------------------------------------
# Ignore all env files anywhere in the workspace
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.sample.local
.env.*.local
*.env
*.env.*
config/.env

# Ignore private keys, SSH keys, credentials, and TLS certificates
*.pem
*.key
*.pub
*.crt
*.p12
*.pfx
*credentials*.json
*secret*.json
secring.gpg
secrets/
.secret*
jwt_secret*

# ------------------------------------------------------------------------------
# 3. Build & Compilation Outputs
# ------------------------------------------------------------------------------
# General build folders
dist/
**/dist/
build/
**/build/
out/
**/out/
target/

# Next.js build and cache
.next/
**/.next/
*.tsbuildinfo
next-env.d.ts

# ------------------------------------------------------------------------------
# 4. Databases, Local Storage, and Prisma
# ------------------------------------------------------------------------------
# Local SQLite and DB files
*.db
*.db-journal
*.sqlite
*.sqlite3
*.sql
*.local

# Auto-generated Prisma/DB clients
/generated/prisma
**/generated/prisma

# ------------------------------------------------------------------------------
# 5. Diagnostic / Debug / Log Files
# ------------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-debug.log*

# ------------------------------------------------------------------------------
# 6. Operating System & Filesystem Artifacts
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db

# ------------------------------------------------------------------------------
# 7. IDE, Text Editors, and Development Environments
# ------------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
.project
.classpath
.settings/
